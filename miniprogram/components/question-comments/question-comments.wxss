.comments-section {
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.comments-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.comments-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #a03a57;
}

.comments-count {
  font-size: 22rpx;
}

.comment-compose {
  margin-bottom: 20rpx;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fbf1f3;
  border: 1rpx solid rgba(219, 192, 196, 0.5);
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

.comment-send {
  width: 100%;
  margin-top: 16rpx;
}

.comment-send::after {
  border: none;
}

.comments-tip,
.comments-state {
  font-size: 24rpx;
  text-align: center;
  padding: 16rpx 0 24rpx;
}

.comment-thread + .comment-thread {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(219, 192, 196, 0.35);
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-reply {
  margin-top: 16rpx;
  margin-left: 72rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(160, 58, 87, 0.12);
  color: #a03a57;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  font-size: 22rpx;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f1a1c;
}

.comment-time {
  font-size: 22rpx;
}

.comment-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #554245;
  word-break: break-word;
}

.comment-reply-btn {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #a03a57;
  font-weight: 700;
}

.reply-compose {
  margin-top: 16rpx;
  margin-left: 72rpx;
}

.reply-input {
  min-height: 96rpx;
}

.reply-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.reply-cancel,
.reply-send {
  flex: 1;
  margin: 0;
}

.reply-cancel {
  background: #ffffff;
  color: #887175;
  border: 1rpx solid rgba(219, 192, 196, 0.6);
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 2.4;
}

.reply-cancel::after {
  border: none;
}

.reply-send::after {
  border: none;
}
