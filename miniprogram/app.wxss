page {
  background: #0f1419;
  color: #e8edf4;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #1a2332;
  border: 1rpx solid #2d3a4f;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-desc {
  color: #8b9cb3;
  font-size: 26rpx;
}

.btn-primary {
  background: #3b82f6;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #243044;
  color: #e8edf4;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-secondary::after {
  border: none;
}

.tag {
  display: inline-block;
  background: #243044;
  color: #93c5fd;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}

.muted {
  color: #8b9cb3;
}
