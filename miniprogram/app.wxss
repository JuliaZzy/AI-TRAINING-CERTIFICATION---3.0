page {
  background: #fff8f8;
  color: #1f1a1c;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(219, 192, 196, 0.4);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(160, 58, 87, 0.08);
}

.glass-card {
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(20px);
}

.btn-primary {
  background: #a03a57;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #dbc0c4;
  color: #ffffff;
}

.btn-secondary {
  background: #ffffff;
  color: #a03a57;
  border: 2rpx solid #a03a57;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary[disabled] {
  background: #f5ebed;
  color: #dbc0c4;
  border-color: #eae0e2;
}

.tag {
  display: inline-block;
  background: #fbf1f3;
  color: #a03a57;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.muted {
  color: #887175;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #887175;
  margin: 8rpx 0 20rpx;
  letter-spacing: 0.04em;
}
