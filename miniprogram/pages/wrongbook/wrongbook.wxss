.page {
  min-height: 100vh;
  background: #fff8f8;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.page-title,
.section-heading {
  font-size: 44rpx;
  font-weight: 700;
}

.week-new {
  font-size: 26rpx;
  color: #887175;
}

.stats-card {
  display: flex;
  gap: 32rpx;
  align-items: center;
}

.donut-wrap {
  flex-shrink: 0;
}

.donut {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 12rpx solid #a03a57;
  border-right-color: #674bb5;
  border-bottom-color: #beaa55;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #a03a57;
}

.donut-label {
  font-size: 22rpx;
  color: #887175;
}

.legend {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot.primary { background: #a03a57; }
.dot.secondary { background: #674bb5; }
.dot.tertiary { background: #beaa55; }

.legend-name {
  display: block;
  font-size: 22rpx;
  color: #887175;
}

.legend-val {
  font-size: 28rpx;
  font-weight: 700;
}

.action-grid {
  display: flex;
  gap: 24rpx;
  margin: 32rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.action-primary,
.action-secondary {
  flex: 1;
  min-width: 0;
  margin: 0;
  width: auto;
  box-sizing: border-box;
  border-radius: 32rpx;
  padding: 36rpx 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.action-primary::after,
.action-secondary::after {
  border: none;
}

.action-primary {
  background: #a03a57;
  color: #ffffff;
}

.action-secondary {
  background: #ffffff;
  color: #a03a57;
  border: 2rpx solid rgba(160, 58, 87, 0.2);
}

.bento-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.bento-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e8ddff;
  color: #674bb5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.bento-text {
  flex: 1;
}

.bento-title {
  font-size: 28rpx;
  font-weight: 700;
}

.bento-desc {
  font-size: 22rpx;
  color: #887175;
  margin-top: 4rpx;
}

.chevron {
  color: #887175;
  font-size: 40rpx;
}

.mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin: 24rpx 0 32rpx;
}

.mini-card {
  padding: 24rpx;
}

.mini-label {
  font-size: 22rpx;
  color: #887175;
  margin-bottom: 16rpx;
}

.mini-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.weak {
  color: #ba1a1a;
}

.mini-num {
  font-weight: 700;
}

.bar {
  height: 8rpx;
  background: #eae0e2;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill.weak {
  background: #ba1a1a;
}

.suggest {
  color: #674bb5;
  font-weight: 700;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  color: #887175;
  padding: 48rpx;
}

.record-type {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  text-transform: uppercase;
}

.record-type.judge,
.record-type.single,
.record-type.multiple {
  background: rgba(160, 58, 87, 0.1);
  color: #a03a57;
}

.record-type.operation {
  background: rgba(103, 75, 181, 0.1);
  color: #674bb5;
}

.record-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mastery {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.mastery.weak {
  background: rgba(186, 26, 26, 0.1);
  color: #ba1a1a;
}

.mastery.medium {
  background: rgba(103, 75, 181, 0.1);
  color: #674bb5;
}

.record-text {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-meta {
  display: flex;
  gap: 24rpx;
  color: #887175;
  font-size: 22rpx;
}
