.page {
  min-height: 100vh;
  background: #fff8f8;
}

.search-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #887175;
  font-size: 32rpx;
}

.search-input {
  height: 96rpx;
  padding: 0 32rpx 0 80rpx;
  background: #fbf1f3;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.download-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  margin-bottom: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ff85a2, #a03a57);
  color: #ffffff;
  box-shadow: 0 8rpx 40rpx rgba(160, 58, 87, 0.2);
}

.download-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.download-desc {
  font-size: 24rpx;
  opacity: 0.85;
}

.download-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.type-card {
  background: #ffffff;
  border: 1rpx solid rgba(219, 192, 196, 0.35);
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 40rpx rgba(160, 58, 87, 0.06);
}

.type-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f5ebed;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-icon {
  font-size: 40rpx;
  color: #a03a57;
}

.type-info {
  flex: 1;
}

.type-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #a03a57;
}

.type-en {
  display: block;
  font-size: 22rpx;
  color: #887175;
  margin-top: 6rpx;
}

.difficulty {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.difficulty.EASY {
  background: rgba(190, 170, 85, 0.3);
  color: #4b3e00;
}

.difficulty.MEDIUM {
  background: rgba(171, 143, 254, 0.5);
  color: #674bb5;
}

.difficulty.HARD {
  background: rgba(255, 133, 162, 0.35);
  color: #771a38;
}

.difficulty.EXPERT {
  background: rgba(255, 218, 214, 0.8);
  color: #93000a;
}

.daily-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.daily-icon {
  width: 88rpx;
  height: 88rpx;
  background: #ffffff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #a03a57;
  box-shadow: 0 4rpx 16rpx rgba(160, 58, 87, 0.08);
}

.daily-info {
  flex: 1;
}

.daily-title {
  font-size: 30rpx;
  font-weight: 600;
}

.daily-desc {
  font-size: 24rpx;
  color: #887175;
  margin-top: 6rpx;
}

.progress-ring {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #eae0e2;
  border-top-color: #674bb5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #554245;
}
