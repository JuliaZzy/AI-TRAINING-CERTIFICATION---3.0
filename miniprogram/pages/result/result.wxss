.score-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.score-title {
  font-size: 30rpx;
  color: #8b9cb3;
  margin-bottom: 24rpx;
}

.score-main {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.score-num {
  font-size: 88rpx;
  font-weight: 700;
  color: #3b82f6;
  line-height: 1;
}

.score-slash,
.score-max {
  font-size: 40rpx;
  color: #8b9cb3;
  margin-left: 8rpx;
}

.score-sub {
  color: #8b9cb3;
  font-size: 26rpx;
}

.stats {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  background: #243044;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8b9cb3;
}

.stat-item.ok .stat-num {
  color: #22c55e;
}

.stat-item.bad .stat-num {
  color: #ef4444;
}

.stat-item.pending .stat-num {
  color: #f59e0b;
}

.section-title {
  font-size: 28rpx;
  color: #8b9cb3;
  margin: 24rpx 0 20rpx;
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.status {
  font-size: 24rpx;
}

.status.ok {
  color: #22c55e;
}

.status.bad {
  color: #ef4444;
}

.status.pending {
  color: #f59e0b;
}

.detail-text {
  font-size: 28rpx;
}

.detail-answer {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #93c5fd;
}

.bottom-actions {
  padding: 24rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
}
