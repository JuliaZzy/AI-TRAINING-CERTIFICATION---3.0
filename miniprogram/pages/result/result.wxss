page {
  background: #fff8f8;
  color: #1f1a1c;
}

.score-card {
  text-align: center;
}

.score-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.score-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #a03a57;
}

.score-slash,
.score-max {
  font-size: 36rpx;
  color: #887175;
}

.score-sub {
  color: #887175;
  margin-top: 8rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
}

.stat-item.ok .stat-num { color: #674bb5; }
.stat-item.bad .stat-num { color: #ba1a1a; }
.stat-item.pending .stat-num { color: #887175; }

.stat-label {
  font-size: 24rpx;
  color: #887175;
}

.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.status {
  font-size: 22rpx;
  font-weight: 700;
}

.status.ok { color: #674bb5; }
.status.bad { color: #ba1a1a; }
.status.pending { color: #887175; }

.detail-text {
  font-size: 28rpx;
}

.detail-answer {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #a03a57;
}

.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 48rpx;
}

.action-btn {
  width: 100%;
}
