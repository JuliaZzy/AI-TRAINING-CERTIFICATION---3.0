.page {
  min-height: 100vh;
  background: #fff8f8;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 40rpx;
  background: linear-gradient(180deg, #fbf1f3, transparent);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
}

.avatar-ring {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, #a03a57, #674bb5, #beaa55);
  box-shadow: 0 8rpx 48rpx rgba(160, 58, 87, 0.15);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
  border: 6rpx solid #fff8f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 700;
  color: #a03a57;
}

.edit-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #a03a57;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 4rpx solid #fff8f8;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-top: 24rpx;
}

.profile-id {
  font-size: 26rpx;
  margin-top: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 24rpx 16rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
}

.stat-num.primary { color: #a03a57; }
.stat-num.secondary { color: #674bb5; }

.stat-badge {
  font-size: 40rpx;
}

.stat-level {
  font-size: 30rpx;
  font-weight: 700;
  color: #6e5e0d;
  margin-top: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #887175;
  margin-top: 8rpx;
}

.fav-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.fav-card {
  padding: 24rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8rpx 40rpx rgba(160, 58, 87, 0.1);
  box-sizing: border-box;
}

.fav-icon {
  height: 100rpx;
  background: rgba(160, 58, 87, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #a03a57;
  margin-bottom: 16rpx;
}

.fav-title {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

.fav-count {
  font-size: 22rpx;
  margin-top: 6rpx;
}

.menu {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(219, 192, 196, 0.3);
  font-size: 32rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.menu-icon.primary { background: rgba(160, 58, 87, 0.1); color: #a03a57; }
.menu-icon.secondary { background: rgba(103, 75, 181, 0.1); color: #674bb5; }
.menu-icon.tertiary { background: rgba(110, 94, 13, 0.1); color: #6e5e0d; }
.menu-icon.muted { background: rgba(85, 66, 69, 0.1); color: #554245; }

.menu-arrow {
  margin-left: auto;
  color: #887175;
  font-size: 36rpx;
}

.menu-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.badge {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ba1a1a;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-card {
  display: flex;
  gap: 24rpx;
  align-items: center;
  margin-top: 32rpx;
  border: 1rpx solid rgba(255, 133, 162, 0.25);
}

.ai-icon {
  font-size: 56rpx;
  color: #a03a57;
}

.ai-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #a03a57;
}

.ai-desc {
  font-size: 26rpx;
  color: #554245;
  margin-top: 8rpx;
}
