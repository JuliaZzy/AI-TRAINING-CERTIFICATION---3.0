<view class="page">
  <custom-nav mode="brand" title="QuestMind" />

  <view class="container">
    <view class="profile-header">
      <view class="avatar-ring">
        <view class="avatar">学</view>
        <view class="edit-btn">✎</view>
      </view>
      <view class="profile-name">{{profile.nickname}}</view>
      <view class="profile-id muted">ID: {{profile.id}}</view>
    </view>

    <view class="stats-grid">
      <view class="stat-box card">
        <text class="stat-num primary">{{profile.streak}}</text>
        <text class="stat-label">连续学习</text>
      </view>
      <view class="stat-box card">
        <text class="stat-num secondary">{{profile.solved}}</text>
        <text class="stat-label">解决题目</text>
      </view>
      <view class="stat-box card">
        <text class="stat-badge">🏅</text>
        <text class="stat-level">{{profile.level}}</text>
        <text class="stat-label">称号等级</text>
      </view>
    </view>

    <view class="section-title">我的收藏</view>
    <view class="fav-grid">
      <block wx:for="{{favorites}}" wx:key="key">
        <view class="fav-card glass-card" bindtap="startFavorite" data-type="{{item.key}}">
          <view class="fav-icon">{{item.icon}}</view>
          <view class="fav-title">{{item.title}}</view>
          <view class="fav-count muted">{{item.count}} 题目</view>
        </view>
      </block>
    </view>

    <view class="menu card">
      <view class="menu-item" bindtap="onMenuTap" data-key="个人设置">
        <view class="menu-icon primary">◉</view>
        <text>个人设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-key="消息中心">
        <view class="menu-icon secondary">◎</view>
        <text>消息中心</text>
        <view class="menu-right">
          <text class="badge">3</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-key="学习提醒">
        <view class="menu-icon tertiary">⏰</view>
        <text>学习提醒</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon muted">☾</view>
        <text>深色模式</text>
        <switch checked="{{darkMode}}" bindchange="toggleDarkMode" color="#a03a57" />
      </view>
      <view class="menu-item" bindtap="onMenuTap" data-key="关于我们">
        <view class="menu-icon muted">ℹ</view>
        <text>关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="ai-card glass-card card">
      <text class="ai-icon">✦</text>
      <view class="ai-text">
        <view class="ai-title">QuestAI 助手</view>
        <view class="ai-desc">"你今天的学习效率超过了 92% 的探险者，继续加油！"</view>
      </view>
    </view>
  </view>
</view>
