.top-bar {
  position: sticky;
  top: 0;
  z-index: 10;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.top-meta {
  color: #93c5fd;
  font-size: 24rpx;
}

.question {
  margin-bottom: 24rpx;
}

.q-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.q-index {
  font-size: 28rpx;
  font-weight: 600;
}

.q-score {
  color: #f59e0b;
  font-size: 24rpx;
}

.q-text {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.q-hint {
  color: #8b9cb3;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  background: #243044;
  border: 1rpx solid #2d3a4f;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
}

.option.selected {
  border-color: #3b82f6;
  background: rgba(59, 130, 246, 0.15);
}

.option.correct {
  border-color: #22c55e;
  background: rgba(34, 197, 94, 0.12);
}

.option.wrong {
  border-color: #ef4444;
  background: rgba(239, 68, 68, 0.12);
}

.opt-key {
  font-weight: 700;
  margin-right: 12rpx;
}

.code-block {
  background: #0f1419;
  border: 1rpx solid #2d3a4f;
  border-radius: 16rpx;
  padding: 24rpx;
  overflow-x: auto;
}

.code-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.code-text {
  font-family: Consolas, "Courier New", monospace;
  font-size: 24rpx;
  color: #cbd5e1;
  white-space: pre-wrap;
  word-break: break-all;
}

.code-input {
  min-width: 120rpx;
  max-width: 360rpx;
  height: 56rpx;
  padding: 0 16rpx;
  background: #1a2332;
  border: 1rpx solid #3b82f6;
  border-radius: 8rpx;
  color: #fff;
  font-family: Consolas, "Courier New", monospace;
  font-size: 24rpx;
}

.code-input.input-correct {
  border-color: #22c55e;
  color: #22c55e;
}

.code-input.input-wrong {
  border-color: #ef4444;
  color: #ef4444;
}

.answer-box {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #93c5fd;
}

.answer-label {
  font-weight: 600;
  margin-right: 8rpx;
}

.bottom-actions {
  padding: 16rpx 0 48rpx;
}

.submit-btn {
  width: 100%;
}
