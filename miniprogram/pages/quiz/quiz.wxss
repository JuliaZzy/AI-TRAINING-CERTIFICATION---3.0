.page {
  min-height: 100vh;
  background: #fff8f8;
  padding-bottom: 200rpx;
}

.progress-footer {
  padding: 0 32rpx 16rpx;
}

.nav-skip {
  font-size: 28rpx;
  color: #887175;
}

.progress-track {
  height: 12rpx;
  background: #efe6e8;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #ff85a2;
  border-radius: 999rpx;
  transition: width 0.4s ease;
  box-shadow: 0 0 8rpx rgba(160, 58, 87, 0.3);
}

.quest-card {
  margin-top: 16rpx;
}

.question-text {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #1f1a1c;
}

.hint-btn {
  margin-top: 32rpx;
  align-self: flex-end;
  display: inline-flex;
  padding: 12rpx 24rpx;
  background: #f9e287;
  color: #6e5e0d;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.hint-box {
  margin-top: 16rpx;
  padding: 20rpx;
  background: rgba(190, 170, 85, 0.12);
  border: 1rpx solid rgba(190, 170, 85, 0.25);
  border-radius: 16rpx;
  color: #6e5e0d;
  font-style: italic;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin: 32rpx 0;
}

.option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(160, 58, 87, 0.04);
}

.option.selected {
  border-color: #ff85a2;
  background: rgba(255, 133, 162, 0.08);
}

.opt-key {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eae0e2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #554245;
  flex-shrink: 0;
}

.option.selected .opt-key {
  background: #ff85a2;
  color: #ffffff;
}

.submit-btn {
  width: 100%;
  margin-top: 16rpx;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 248, 248, 0.95);
}

.nav-action {
  flex: 1;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(31, 26, 28, 0.25);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 32rpx;
}

.modal {
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.modal-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
}

.modal-icon.ok {
  background: #beaa55;
  color: #4b3e00;
}

.modal-icon.warn {
  background: #ffdad6;
  color: #ba1a1a;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.modal-desc {
  color: #554245;
  margin-bottom: 32rpx;
}

.modal-btn {
  width: 100%;
}
