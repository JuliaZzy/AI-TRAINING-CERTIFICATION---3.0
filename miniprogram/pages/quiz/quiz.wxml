<view class="page">
  <custom-nav mode="back" title="{{progressText}}" bind:back="onBack">
    <text slot="right" class="nav-skip" bindtap="onSkip">Skip</text>
    <view slot="footer" class="progress-footer">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
    </view>
  </custom-nav>

  <view class="container" wx:if="{{current}}">
    <view class="quest-card card">
      <view class="question-text">{{current.text}}</view>
      <view class="hint-btn" bindtap="toggleHint">
        <text>💡 Hint</text>
      </view>
      <view wx:if="{{hintVisible}}" class="hint-box">
        提示：仔细审题，关注题干中的关键词。
      </view>
    </view>

    <!-- 判断题 -->
    <view wx:if="{{type === 'judge'}}" class="options">
      <view
        class="option {{selected === 'T' ? 'selected' : ''}}"
        bindtap="onJudgeSelect"
        data-value="T"
      >
        <view class="opt-key">√</view>
        <text>正确</text>
      </view>
      <view
        class="option {{selected === 'F' ? 'selected' : ''}}"
        bindtap="onJudgeSelect"
        data-value="F"
      >
        <view class="opt-key">×</view>
        <text>错误</text>
      </view>
    </view>

    <!-- 单选题 -->
    <view wx:elif="{{type === 'single'}}" class="options">
      <view
        wx:for="{{optionList}}"
        wx:key="key"
        class="option {{selected === item.key ? 'selected' : ''}}"
        bindtap="onSingleSelect"
        data-value="{{item.key}}"
      >
        <view class="opt-key">{{item.key}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- 多选题 -->
    <view wx:elif="{{type === 'multiple'}}" class="options">
      <view
        wx:for="{{optionList}}"
        wx:key="key"
        class="option {{selectedMap[item.key] ? 'selected' : ''}}"
        bindtap="onMultipleToggle"
        data-value="{{item.key}}"
      >
        <view class="opt-key">{{item.key}}</view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <button
      class="submit-btn btn-primary"
      disabled="{{!selected && !selectedList.length}}"
      bindtap="submitAnswer"
    >Check Answer</button>

    <question-comments
      wx:if="{{current}}"
      question-type="{{type}}"
      question-id="{{current.id}}"
    />
  </view>

  <view class="bottom-nav">
    <button class="nav-action btn-secondary" bindtap="goPrev" disabled="{{!canGoPrev}}">‹ 上一题</button>
    <button class="nav-action btn-primary" bindtap="goNext" disabled="{{!canGoNext}}">下一题 ›</button>
  </view>

  <view wx:if="{{showModal}}" class="modal-mask" bindtap="closeModal">
    <view class="modal card" catchtap="">
      <view class="modal-icon {{feedback.positive ? 'ok' : 'warn'}}">
        {{feedback.positive ? '✓' : '!'}}
      </view>
      <view class="modal-title">{{feedback.title}}</view>
      <view class="modal-desc">{{feedback.desc}}</view>
      <button class="btn-primary modal-btn" bindtap="closeModal">Next Quest</button>
    </view>
  </view>
</view>
